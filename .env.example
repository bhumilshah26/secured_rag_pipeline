# ---- Core ----
APP_ENV=development
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- PostgreSQL ----
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ---- Qdrant ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_chunks

# ---- Embeddings (pluggable) ----
# EMBEDDING_PROVIDER: fastembed | openai
EMBEDDING_PROVIDER=fastembed
FASTEMBED_MODEL=BAAI/bge-large-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Document extraction / OCR ----
OCR_ENABLED=true
TESSERACT_CMD=
POPPLER_PATH=

# ---- LLM (pluggable) ----
# LLM_PROVIDER: echo | openai | anthropic
LLM_PROVIDER=echo
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Connectors ----
COMPOSIO_API_KEY=
# Developer-side Composio auth-config ids (one per toolkit). Users never enter these.
COMPOSIO_AUTHCONFIG_GDRIVE=
COMPOSIO_AUTHCONFIG_ONEDRIVE=
COMPOSIO_AUTHCONFIG_SHAREPOINT=
COMPOSIO_AUTHCONFIG_CONFLUENCE=
COMPOSIO_AUTHCONFIG_SLACK=

# ---- Security thresholds (prompt guard) ----
PROMPT_GUARD_FLAG_THRESHOLD=40
PROMPT_GUARD_BLOCK_THRESHOLD=70

# ---- Frontend ----
NEXT_PUBLIC_API_BASE=http://localhost:8000
